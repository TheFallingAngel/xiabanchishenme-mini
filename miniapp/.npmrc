# Taro / Webpack 5 的 loader 走"按名解析"而不是 require.resolve,pnpm 默认严格隔离会找不到
# 间接依赖。node-linker=hoisted 让 pnpm 把所有包平铺到 node_modules/ 根 (和 npm 行为一致)。
# 具体症状: webpack.cache.PackFileCacheStrategy warn "Can't resolve '@tarojs/taro-loader/lib/page'"
node-linker=hoisted

# shamefully-hoist 是同义的老开关,保留兼容
shamefully-hoist=true
