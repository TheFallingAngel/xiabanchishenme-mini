# 高德地图 Web 服务 API Key（服务端用 — POI 搜索/步行路径）
AMAP_API_KEY=your_amap_web_service_key_here

# 高德地图 JS API Key（前端渲染详情页地图、浏览器定位）
# 注意：这个 Key 需要在高德开放平台开启「Web端（JS API）」服务
NEXT_PUBLIC_AMAP_JS_KEY=your_amap_js_key_here

# 高德地图 JS API 安全密钥（**必填**，否则底图灰屏）
# 自 2021-12-02 起新申请的 JS Key 必须配对 securityJsCode，
# 缺失时瓦片请求会返回 INVALID_USER_SCODE，只显示底色+比例尺，没有街道/POI 文字。
# 获取方式：高德控制台 → 应用管理 → 你的应用 → Web 端(JS API) Key 右侧「安全密钥」
NEXT_PUBLIC_AMAP_JS_SECURITY_CODE=your_amap_js_security_code_here
# ⚠️ 部署前 checklist：
#   1. Key 与 SecurityCode 必须是"同一个 Web 端(JSAPI) 应用"下的配套
#   2. 不要用 Web 服务端 Key 或 移动端 Key
#   3. 高德控制台的「域名白名单」要包含线上实际 host (xxx.vercel.app / 自定义域名)
#   4. 若用 Preview 部署,Vercel 的随机域名也得加到白名单,否则 Preview 会灰屏

# MiniMax LLM OpenAI 兼容接口（生成个性化推荐理由，缺失时自动降级为模板文案）
# 文档：https://platform.minimaxi.com/docs/guides/quickstart-preparation
MINIMAX_API_KEY=your_minimax_api_key_here
# 可选：自定义模型（默认 MiniMax-M2.7-highspeed；可用 MiniMax-M2.7/MiniMax-M2.5/MiniMax-M2.1）
# MINIMAX_MODEL=MiniMax-M2.7-highspeed
# 可选：自定义 API URL（默认 https://api.minimaxi.com/v1/chat/completions）
# MINIMAX_API_URL=https://api.minimaxi.com/v1/chat/completions
